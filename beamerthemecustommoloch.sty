\ProvidesPackage{beamerthemecustommoloch}[2025/10/23 Custom tweaks for the Moloch beamer theme]

\newcommand{\custommoloch@numbering}{none}
\DeclareOptionBeamer{numbering}{\renewcommand{\custommoloch@numbering}{#1}}
\DeclareOptionBeamer{progressbar}{\PassOptionsToPackage{progressbar=#1}{beamerthememoloch}}
\DeclareOptionBeamer*{\PassOptionsToPackage{\CurrentOption}{beamerthememoloch}}
\ProcessOptionsBeamer

\RequirePackage{beamerthememoloch}
\RequirePackage{fontawesome5}

\definecolor{SoftRed}{HTML}{E57373}
\setbeamercolor{frametitle}{fg=white,bg=SoftRed}
\setbeamerfont{section in head/foot}{size=\footnotesize,series=\bfseries}

\setbeamersize{text margin left=0.5cm,text margin right=0.5cm}

\newcommand*{\custommolochContact}{clou@us.es}
% ETSII (8722x1162, ratio 7.5:1): width-limited at 0.30\paperwidth → short but fills slot
% US   (671x582,   ratio 1.15:1): height-limited at 0.13\paperheight
% IBIS (165x73,    ratio 2.26:1): height-limited at 0.13\paperheight
\newcommand*{\custommolochInsertLogo}{%
  \IfFileExists{figs/logos/us-logo.pdf}{\includegraphics[height=0.10\paperheight,width=0.25\paperwidth,keepaspectratio]{figs/logos/us-logo.pdf}}{%
    \IfFileExists{figs/logos/us-logo.png}{\includegraphics[height=0.10\paperheight,width=0.25\paperwidth,keepaspectratio]{figs/logos/us-logo.png}}{}}}
\newcommand*{\custommolochInsertEtsiiLogo}{%
  \IfFileExists{figs/logos/logo-ETSII-Color.pdf}{\includegraphics[height=0.10\paperheight,width=0.25\paperwidth,keepaspectratio]{figs/logos/logo-ETSII-Color.pdf}}{%
    \IfFileExists{figs/logos/logo-ETSII-Color.png}{\includegraphics[height=0.10\paperheight,width=0.25\paperwidth,keepaspectratio]{figs/logos/logo-ETSII-Color.png}}{}}}
\newcommand*{\custommolochInsertIbisLogo}{%
  \IfFileExists{figs/logos/ibis-logo.pdf}{\includegraphics[height=0.10\paperheight,width=0.25\paperwidth,keepaspectratio]{figs/logos/ibis-logo.pdf}}{%
    \IfFileExists{figs/logos/ibis-logo.png}{\includegraphics[height=0.10\paperheight,width=0.25\paperwidth,keepaspectratio]{figs/logos/ibis-logo.png}}{}}}

\makeatletter
\setlength{\moloch@frametitle@padding}{1.2ex}
\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \begin{beamercolorbox}[
    wd=\paperwidth,
    leftskip=0.8ex,
    rightskip=\the\glueexpr 0.8ex plus 1fil\relax,
  ]{frametitle}%
    \usebeamerfont{frametitle}%
    \moloch@frametitlestrut@start%
    \insertframetitle%
    \ifx\insertsectionhead\@empty%
    \else%
      \hfill%
      {\usebeamerfont{section in head/foot}%
       \usebeamercolor[fg]{section in head/foot}%
       \rule[-\moloch@frametitle@padding]{0.6pt}{\dimexpr\moloch@frametitle@padding+\ht\strutbox\relax}%
       \hspace{0.75ex}%
       \insertsectionhead}%
    \fi%
    \moloch@frametitlestrut@end%
    \ifx\insertframesubtitle\@empty%
    \else%
      \par%
      \vspace{-0.8ex}%
      {\usebeamerfont{framesubtitle}%
       \usebeamercolor[fg]{framesubtitle}%
       \insertframesubtitle}%
    \fi%
  \end{beamercolorbox}%
}
\makeatother

\setbeamerfont{footline}{size=\scriptsize}
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth,leftskip=1.6ex,rightskip=1.6ex,ht=2.6ex,dp=1.0ex]{footline}%
    \usebeamerfont{footline}%
    \usebeamercolor[fg]{footline}%
    \hfill%
    \usebeamertemplate*{page number in head/foot}%
    \hfill%
  \end{beamercolorbox}%
}

\makeatletter
\newcommand{\custommoloch@numbering@fraction}{%
  \setbeamertemplate{page number in head/foot}{%
    \usebeamerfont{page number in head/foot}%
    \insertframenumber%
    \ifnum\inserttotalframenumber>0\relax/\inserttotalframenumber\fi%
  }%
}

\newcommand{\custommoloch@numbering@none}{%
  \setbeamertemplate{page number in head/foot}[default]%
}

\newcommand{\custommoloch@numbering@unknown}{%
  \PackageWarning{beamerthemecustommoloch}{Unknown numbering option `\custommoloch@numbering'. Using default}%
  \custommoloch@numbering@none
}

\newcommand{\custommoloch@applynumbering}{%
  \ifcsname custommoloch@numbering@\custommoloch@numbering\endcsname
    \csname custommoloch@numbering@\custommoloch@numbering\endcsname
  \else
    \custommoloch@numbering@unknown
  \fi
}
\custommoloch@applynumbering
\makeatother

\setbeamertemplate{author}{%
  \raggedright%
  \insertauthor%
  \enspace{\scriptsize\faIcon{envelope}\,\href{mailto:\custommolochContact}{\custommolochContact}}%
  \par%
  \vspace*{0.5em}%
}

\setbeamertemplate{title}{%
  \centering%
  \vspace*{1.5em}%
  \linespread{1.0}%
  \inserttitle%
  \par%
  \vspace*{0.5em}%
}

\makeatletter
\setbeamertemplate{title graphic}{%
  \begin{tikzpicture}[remember picture,overlay]
    % thin separator above the logo strip
    \draw[gray!40, line width=0.4pt]
      ([xshift=1.6ex, yshift=0.22\paperheight]current page.south west) --
      ([xshift=-1.6ex,yshift=0.22\paperheight]current page.south east);
    % ETSII — left third, vertically centered in logo strip
    \node[anchor=center,xshift=0.17\paperwidth,yshift=0.08\paperheight] at (current page.south west){%
      \custommolochInsertEtsiiLogo};
    % US — center third, vertically centered in logo strip
    \node[anchor=center,yshift=0.08\paperheight] at (current page.south){%
      \custommolochInsertLogo};
    % IBIS — right third, vertically centered in logo strip
    \node[anchor=center,xshift=-0.17\paperwidth,yshift=0.08\paperheight] at (current page.south east){%
      \custommolochInsertIbisLogo};
  \end{tikzpicture}%
}
\makeatother

% Trigger the title graphic template (TikZ overlay needs non-empty titlegraphic)
\csname titlegraphic\endcsname{\phantom{x}}

% Override title page: replace the bottom \vfill with a fixed space so the date
% doesn't drift into the logo strip drawn by the title graphic overlay.
\makeatletter
\setbeamertemplate{title page}{%
  \begin{minipage}[b][\paperheight]{\textwidth}
    \ifx\inserttitlegraphic\@empty\else\usebeamertemplate*{title graphic}\fi
    \vfill%
    \ifx\inserttitle\@empty\else\usebeamertemplate*{title}\fi
    \ifx\insertsubtitle\@empty\else\usebeamertemplate*{subtitle}\fi
    \usebeamertemplate*{title separator}%
    \ifx\beamer@shortauthor\@empty\else\usebeamertemplate*{author}\fi
    \ifx\insertinstitute\@empty\else\usebeamertemplate*{institute}\fi
    \ifx\insertdate\@empty\else\usebeamertemplate*{date}\fi
    \vspace{0.25\paperheight}%
  \end{minipage}%
}
\makeatother

\makeatletter
\expandafter\let\csname beamer@@tmpop@section page@simple\endcsname\relax
\expandafter\let\csname beamer@@tmpop@section page@progressbar\endcsname\relax
\defbeamertemplate{section page}{simple}{%
  \begin{center}
    \usebeamercolor[fg]{section title}
    \usebeamerfont{section title}
    \insertsection\par
    \ifx\insertsubsectionhead\@empty\else
      \usebeamercolor[fg]{subsection title}
      \usebeamerfont{subsection title}
      \insertsubsectionhead
    \fi
  \end{center}
}
\defbeamertemplate{section page}{progressbar}{%
  \centering
  \begin{minipage}{0.7875\linewidth}
    \raggedright
    \usebeamercolor[fg]{section title}
    \usebeamerfont{section title}
    \insertsection\\[-1ex]
    \usebeamertemplate*{progress bar in section page}
    \par
    \ifx\insertsubsectionhead\@empty\else%
      \usebeamercolor[fg]{subsection title}%
      \usebeamerfont{subsection title}%
      \insertsubsectionhead
    \fi
  \end{minipage}
  \par
  \vspace{\baselineskip}
}
\setbeamertemplate{section page}[progressbar]
\makeatother

